# Rust runtime
RUST_LOG=info
APP_ENV=development
API_PORT=8080
WEB_PORT=3000

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=finance_assistant
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=change_me

JWT_ISSUER=finance-assistant
JWT_AUDIENCE=finance-assistant-users
JWT_SECRET=replace_with_long_random_secret
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

AI_SERVICE_TOKEN=replace_with_random_service_token
OPENAI_API_KEY=replace_if_used

STORAGE_PROVIDER=Local
STORAGE_BASE_PATH=/data/uploads

OPENCLAW_BASE_URL=http://openclaw:3001
OPENCLAW_WEBHOOK_SECRET=replace_with_secret

CORS_ALLOWED_ORIGINS=http://localhost:3000
