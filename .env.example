# ─── Application ─────────────────────────────────────────────────────────────
APP_ENV=development
API_PORT=8080
WEB_PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
POSTGRES_DB=finance_db
POSTGRES_USER=finance_user
POSTGRES_PASSWORD=changeme_strong_password
POSTGRES_PORT=5432
DATABASE_URL=postgres://finance_user:changeme_strong_password@localhost:5432/finance_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_very_long_random_secret_min_64_chars
JWT_ACCESS_TOKEN_MINUTES=30
JWT_REFRESH_TOKEN_DAYS=14

# ─── AI / OpenClaw ────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-your-openai-api-key
AI_SERVICE_TOKEN=change_this_openclaw_service_token

# ─── Storage ──────────────────────────────────────────────────────────────────
STORAGE_BASE_PATH=/data/uploads
STORAGE_BASE_URL=http://localhost:8080/uploads

# ─── Logging ──────────────────────────────────────────────────────────────────
RUST_LOG=info

# ─── Frontend ─────────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:8080/api
